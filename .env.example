# macOS code signing + notarization (optional)
#
# Copy this file to `.env` and fill in the values to sign & notarize local
# `npm run make` builds. When these are unset, the build is simply left
# unsigned (forge.config.ts skips osxSign/osxNotarize automatically).
#
# Prerequisites:
#   - Apple Developer Program membership
#   - A "Developer ID Application" certificate installed in your login keychain
#     (verify with: security find-identity -v -p codesigning)
#   - An App Store Connect API key (.p8) for notarization
#
# NOTE: `.env` is git-ignored. Never commit real credentials.
# In CI these are provided as GitHub Secrets instead (see
# .github/workflows/release.yml) — there the key is passed base64-encoded as
# APPLE_API_KEY_B64 rather than a file path.
#
# Electron Forge does NOT auto-load .env, so load it into your shell first:
#   set -a; source .env; set +a; npm run make
# (or use a tool like dotenv-cli: `dotenv -- npm run make`).

# Absolute path to the App Store Connect API key file (AuthKey_XXXXXX.p8).
APPLE_API_KEY_PATH=/Users/you/private_keys/AuthKey_XXXXXX.p8

# The API key's Key ID (the XXXXXX part of the filename).
APPLE_API_KEY_ID=XXXXXXXXXX

# The API key's Issuer ID (App Store Connect > Users and Access > Integrations).
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
